{
  "version": 2,
  "builds": [
    {
      "src": "api/research.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/research", "dest": "/api/research.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}